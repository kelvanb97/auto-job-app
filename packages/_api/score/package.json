{
	"name": "@aja-api/score",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"sideEffects": false,
	"exports": {
		"./api/*": "./src/api/*.ts",
		"./schema/*": "./src/schema/*.ts",
		"./prompt/*": "./src/prompt/*.ts",
		"./lib/*": "./src/lib/*.ts"
	},
	"scripts": {
		"check-types": "tsc --noEmit",
		"lint": "eslint ./src"
	},
	"peerDependencies": {
		"zod": "^4.3.6"
	},
	"dependencies": {
		"@aja-api/company": "workspace:*",
		"@aja-api/role": "workspace:*",
		"@aja-app/drizzle": "workspace:*",
		"@aja-config/user": "workspace:*",
		"@aja-core/drizzle": "workspace:*",
		"@aja-core/result": "workspace:*",
		"@aja-integrations/anthropic": "workspace:*",
		"drizzle-orm": "0.44.2"
	},
	"devDependencies": {
		"@aja-core/eslint": "workspace:*",
		"@aja-core/tsconfig": "workspace:*",
		"@types/node": "25.5.0",
		"eslint": "9.24.0",
		"typescript": "5.9.3",
		"zod": "4.3.6"
	},
	"imports": {
		"#*": [
			"./src/*",
			"./src/*.ts",
			"./src/*.tsx"
		],
		"#api*": [
			"./src/api*",
			"./src/api*.ts"
		],
		"#schema*": [
			"./src/schema*",
			"./src/schema*.ts"
		],
		"#prompt*": [
			"./src/prompt*",
			"./src/prompt*.ts"
		],
		"#lib*": [
			"./src/lib*",
			"./src/lib*.ts"
		]
	}
}
