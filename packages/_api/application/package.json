{
  "name": "@aja-api/application",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./api/*": "./src/api/*.ts",
    "./schema/*": "./src/schema/*.ts"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "lint": "eslint ./src"
  },
  "peerDependencies": {
    "@aja-core/supabase-next-auth": "workspace:*",
    "zod": "^4.1.12"
  },
  "dependencies": {
    "@aja-core/result": "workspace:*"
  },
  "devDependencies": {
    "@aja-app/supabase": "workspace:*",
    "@aja-core/eslint": "workspace:*",
    "@aja-core/supabase-next-auth": "workspace:*",
    "@aja-core/tsconfig": "workspace:*",
    "eslint": "9.24.0",
    "@types/node": "20.19.2",
    "typescript": "5.8.3",
    "zod": "4.1.12"
  },
  "imports": {
    "#*": ["./src/*", "./src/*.ts", "./src/*.tsx"],

    "#api*": ["./src/api*", "./src/api*.ts"],
    "#schema*": ["./src/schema*", "./src/schema*.ts"]
  }
}
