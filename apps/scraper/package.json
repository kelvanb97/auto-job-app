{
	"name": "scraper",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"scrape": "node --env-file=.env --import=tsx src/index.ts",
		"scrape:himalayas": "node --env-file=.env --import=tsx src/index.ts --source himalayas",
		"scrape:jobicy": "node --env-file=.env --import=tsx src/index.ts --source jobicy",
		"scrape:remoteok": "node --env-file=.env --import=tsx src/index.ts --source remoteok",
		"scrape:weworkremotely": "node --env-file=.env --import=tsx src/index.ts --source weworkremotely",
		"scrape:google-jobs": "node --env-file=.env --import=tsx src/index.ts --source google-jobs",
		"scrape:linkedin": "node --env-file=.env --import=tsx src/index.ts --source linkedin",
		"check-types": "tsc --noEmit",
		"lint": "eslint ./src"
	},
	"dependencies": {
		"@aja-app/scraper": "workspace:*",
		"@aja-config/user": "workspace:*"
	},
	"devDependencies": {
		"@aja-app/supabase": "workspace:*",
		"@aja-core/eslint": "workspace:*",
		"@aja-core/tsconfig": "workspace:*",
		"@types/node": "25.5.0",
		"eslint": "9.24.0",
		"tsx": "4.21.0",
		"typescript": "5.9.3"
	}
}
